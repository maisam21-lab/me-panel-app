# Access: no login/password. Set ALLOWED_EMAILS and only those emails can open
# the app (each person types their email once per session). Leave it out (or
# empty) and the app is open - fine for local use.
# ALLOWED_EMAILS = ["maysam.abukashabeh@namaame.com", "jad.hajjar@namaame.com"]

# Copy to secrets.toml and fill in ONLY when deploying (e.g. Streamlit Cloud).
# Locally you do NOT need this file - the app falls back to your gcloud
# Application Default Credentials (run once: gcloud auth application-default login).
#
# The service account needs BigQuery read access on css-operations
# (roles/bigquery.dataViewer + roles/bigquery.jobUser).

[gcp_service_account]
type = "service_account"
project_id = "YOUR_PROJECT"
private_key_id = "..."
private_key = "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
client_email = "YOUR_SA@YOUR_PROJECT.iam.gserviceaccount.com"
client_id = "..."
